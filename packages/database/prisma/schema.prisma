// ============================================
// Post (게시물 — 피드 + 게시판 통합)
// ============================================
model ChPost {
  id              BigInt   @id @default(autoincrement()) @map("post_id")

  authorUserId    BigInt   @map("author_user_id")
  boardId         BigInt?  @map("board_id")
  categoryId      BigInt?  @map("category_id")

  title           String?  @db.VarChar(500)
  content         String
  contentType     String   @default("text") @map("content_type") @db.VarChar(30)
  isPinned        Boolean  @default(false) @map("is_pinned")
  viewCount       Int      @default(0) @map("view_count")

  isActive        Boolean  @default(true) @map("is_active")
  memo            String?
  createdBy       BigInt?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedBy       BigInt?  @map("updated_by")
  updatedAt       DateTime @updatedAt @map("updated_at")
  lastSource      String?  @map("last_source")
  lastActivity    String?  @map("last_activity")
  transactionId   String?  @map("transaction_id") @db.Uuid

  board           ChBoard?          @relation(fields: [boardId], references: [id], onDelete: SetNull)
  category        ChBoardCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  comments        ChComment[]
  reactions       ChReaction[]
  postTags        ChPostTag[]
  mentions        ChMention[]
  attachments     ChAttachment[]
  bookmarks       ChBookmark[]

  @@index([authorUserId], name: "ix_ch_post_m_author")
  @@index([boardId], name: "ix_ch_post_m_board")
  @@index([categoryId], name: "ix_ch_post_m_category")
  @@index([createdAt], name: "ix_ch_post_m_created")
  @@index([isPinned, createdAt], name: "ix_ch_post_m_pinned")
  @@map("ch_post_m")
  @@schema("chs")
}

model ChPostHistory {
  postId          BigInt   @map("post_id")
  historySeq      BigInt   @map("history_seq")

  eventType       String   @map("event_type") @db.Char(1)
  eventAt         DateTime @default(now()) @map("event_at")
