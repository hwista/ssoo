// ============================================
// DMS (Document Management System) Models
// Schema: dms, Prefix: dm_
// ============================================

// ============================================
// Document Control-Plane - dm_document_m
// file/Git content plane 기준 canonical path / revision / visibility 정본
// visibility / grants / requests / sourceFiles / chunk-index / path history 는 relation 으로 분리
// ============================================
model DmsDocument {
  documentId BigInt @id @default(autoincrement()) @map("document_id")

  relativePath       String  @map("relative_path")
  visibilityScope    String  @default("self") @map("visibility_scope")
  targetOrgId        BigInt? @map("target_org_id")
  ownerUserId        BigInt  @map("owner_user_id")
  documentStatusCode String  @default("active") @map("document_status_code")
  syncStatusCode     String  @default("synced") @map("sync_status_code")

  revisionSeq         Int       @default(1) @map("revision_seq")
  contentHash         String    @map("content_hash")
  latestGitCommitHash String?   @map("latest_git_commit_hash")
  // sidecar-compatible top-level metadata projection.
  // visibility/grants/pathHistory/sourceFiles/chunk/index state 는 canonical relation 으로 분리한다.
  metadataJson Json? @map("metadata_jsonb") @db.JsonB

  lastScannedAt    DateTime? @map("last_scanned_at")
  lastSyncedAt     DateTime? @map("last_synced_at")
  lastReconciledAt DateTime? @map("last_reconciled_at")

  isActive      Boolean  @default(true) @map("is_active")
  memo          String?
  createdBy     BigInt?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedBy     BigInt?  @map("updated_by")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lastSource    String?  @map("last_source")
  lastActivity  String?  @map("last_activity")
