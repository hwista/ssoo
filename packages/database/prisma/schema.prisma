  @@index([boardId], name: "ix_cms_board_category_m_board")
  @@map("cms_board_category_m")
  @@schema("cms")
}

// ============================================
// Post (게시물 — 피드 + 게시판 통합)
// ============================================
model CmsPost {
  id BigInt @id @default(autoincrement()) @map("post_id")

  authorUserId BigInt  @map("author_user_id")
  boardId      BigInt? @map("board_id")
  categoryId   BigInt? @map("category_id")

  title       String? @db.VarChar(500)
  content     String
  contentType String  @default("text") @map("content_type") @db.VarChar(30)
  visibilityScopeCode String  @default("public") @map("visibility_scope_code") @db.VarChar(30)
  targetOrgId         BigInt? @map("target_org_id")
  isPinned    Boolean @default(false) @map("is_pinned")
  viewCount   Int     @default(0) @map("view_count")

  isActive      Boolean  @default(true) @map("is_active")
  memo          String?
  createdBy     BigInt?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedBy     BigInt?  @map("updated_by")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lastSource    String?  @map("last_source")
  lastActivity  String?  @map("last_activity")
  transactionId String?  @map("transaction_id") @db.Uuid

  board       CmsBoard?         @relation(fields: [boardId], references: [id], onDelete: SetNull)
  category    CmsBoardCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  comments    CmsComment[]
  reactions   CmsReaction[]
  postTags    CmsPostTag[]
  mentions    CmsMention[]
  attachments CmsAttachment[]
  bookmarks   CmsBookmark[]

  @@index([authorUserId], name: "ix_cms_post_m_author")
  @@index([boardId], name: "ix_cms_post_m_board")
  @@index([categoryId], name: "ix_cms_post_m_category")
  @@index([createdAt], name: "ix_cms_post_m_created")
  @@index([isPinned, createdAt], name: "ix_cms_post_m_pinned")
  @@index([visibilityScopeCode, createdAt], name: "ix_cms_post_m_visibility")
  @@index([targetOrgId, createdAt], name: "ix_cms_post_m_target_org")
  @@map("cms_post_m")
  @@schema("cms")
}

model CmsPostHistory {
  postId     BigInt @map("post_id")
  historySeq BigInt @map("history_seq")

  eventType String   @map("event_type") @db.Char(1)
  eventAt   DateTime @default(now()) @map("event_at")
  eventBy   BigInt?  @map("event_by")

  authorUserId BigInt  @map("author_user_id")
  boardId      BigInt? @map("board_id")
  categoryId   BigInt? @map("category_id")
  title        String? @db.VarChar(500)
  content      String
  contentType  String  @map("content_type") @db.VarChar(30)
  visibilityScopeCode String  @map("visibility_scope_code") @db.VarChar(30)
  targetOrgId         BigInt? @map("target_org_id")
  isPinned     Boolean @map("is_pinned")
  viewCount    Int     @map("view_count")

  isActive      Boolean  @map("is_active")
  memo          String?
  createdBy     BigInt?  @map("created_by")
  createdAt     DateTime @map("created_at")
  updatedBy     BigInt?  @map("updated_by")
  updatedAt     DateTime @map("updated_at")
  lastSource    String?  @map("last_source")
  lastActivity  String?  @map("last_activity")
  transactionId String?  @map("transaction_id") @db.Uuid

  @@id([postId, historySeq], name: "pk_cms_post_h")
  @@index([eventAt], name: "ix_cms_post_h_event_at")
  @@index([transactionId], name: "ix_cms_post_h_tx")
  @@map("cms_post_h")
  @@schema("cms")
}

// ============================================
// Comment (댓글 — 대댓글 self-reference)
// ============================================
model CmsComment {
  id BigInt @id @default(autoincrement()) @map("comment_id")

  postId          BigInt  @map("post_id")
  authorUserId    BigInt  @map("author_user_id")
  parentCommentId BigInt? @map("parent_comment_id")

  content String
  depth   Int    @default(0)

  isActive      Boolean  @default(true) @map("is_active")
  createdBy     BigInt?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedBy     BigInt?  @map("updated_by")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lastSource    String?  @map("last_source")
  lastActivity  String?  @map("last_activity")
  transactionId String?  @map("transaction_id") @db.Uuid

  post          CmsPost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentComment CmsComment?   @relation("CommentThread", fields: [parentCommentId], references: [id], onDelete: SetNull)
  childComments CmsComment[]  @relation("CommentThread")
  reactions     CmsReaction[]
  mentions      CmsMention[]

  @@index([postId, createdAt], name: "ix_cms_comment_m_post")
  @@index([authorUserId], name: "ix_cms_comment_m_author")
  @@index([parentCommentId], name: "ix_cms_comment_m_parent")
  @@map("cms_comment_m")
  @@schema("cms")
}

model CmsCommentHistory {
  commentId  BigInt @map("comment_id")
  historySeq BigInt @map("history_seq")

  eventType String   @map("event_type") @db.Char(1)
  eventAt   DateTime @default(now()) @map("event_at")
  eventBy   BigInt?  @map("event_by")

  postId          BigInt  @map("post_id")
  authorUserId    BigInt  @map("author_user_id")
  parentCommentId BigInt? @map("parent_comment_id")
  content         String
  depth           Int

  isActive      Boolean  @map("is_active")
  createdBy     BigInt?  @map("created_by")
  createdAt     DateTime @map("created_at")
  updatedBy     BigInt?  @map("updated_by")
  updatedAt     DateTime @map("updated_at")
  lastSource    String?  @map("last_source")
  lastActivity  String?  @map("last_activity")
  transactionId String?  @map("transaction_id") @db.Uuid

  @@id([commentId, historySeq], name: "pk_cms_comment_h")
  @@index([eventAt], name: "ix_cms_comment_h_event_at")
  @@index([transactionId], name: "ix_cms_comment_h_tx")
  @@map("cms_comment_h")
  @@schema("cms")
}

// ============================================
// Reaction (반응/좋아요 — 다형성: 게시물·댓글)
// ============================================
model CmsReaction {
  id BigInt @id @default(autoincrement()) @map("reaction_id")

  userId       BigInt  @map("user_id")
  postId       BigInt? @map("post_id")
  commentId    BigInt? @map("comment_id")
  reactionType String  @default("like") @map("reaction_type") @db.VarChar(30)

  createdAt DateTime @default(now()) @map("created_at")

  post    CmsPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment CmsComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, reactionType], name: "uq_cms_reaction_post")
  @@unique([userId, commentId, reactionType], name: "uq_cms_reaction_comment")
  @@index([postId], name: "ix_cms_reaction_m_post")
  @@index([commentId], name: "ix_cms_reaction_m_comment")
  @@map("cms_reaction_m")
  @@schema("cms")
}

// ============================================
// Tag (태그 마스터)
// ============================================
model CmsTag {
  id BigInt @id @default(autoincrement()) @map("tag_id")

  tagName    String @unique @map("tag_name") @db.VarChar(100)
  usageCount Int    @default(0) @map("usage_count")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  postTags CmsPostTag[]

  @@index([usageCount], name: "ix_cms_tag_m_usage")
  @@map("cms_tag_m")
  @@schema("cms")
}

// ============================================
// Post-Tag Relation (게시물-태그)
// ============================================
model CmsPostTag {
  postId BigInt @map("post_id")
  tagId  BigInt @map("tag_id")

  createdAt DateTime @default(now()) @map("created_at")

  post CmsPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  CmsTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId], name: "pk_cms_post_tag_r")
  @@index([tagId], name: "ix_cms_post_tag_r_tag")
  @@map("cms_post_tag_r")
  @@schema("cms")
}

// ============================================
// Mention (멘션 @유저)
// ============================================
model CmsMention {
  id BigInt @id @default(autoincrement()) @map("mention_id")

  mentionedUserId BigInt  @map("mentioned_user_id")
  postId          BigInt? @map("post_id")
  commentId       BigInt? @map("comment_id")

  createdAt DateTime @default(now()) @map("created_at")

  post    CmsPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment CmsComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([mentionedUserId], name: "ix_cms_mention_m_user")
  @@index([postId], name: "ix_cms_mention_m_post")
  @@index([commentId], name: "ix_cms_mention_m_comment")
  @@map("cms_mention_m")
  @@schema("cms")
}

// ============================================
// Attachment (첨부파일)
// ============================================
model CmsAttachment {
  id BigInt @id @default(autoincrement()) @map("attachment_id")

  postId    BigInt @map("post_id")
  fileName  String @map("file_name") @db.VarChar(500)
  filePath  String @map("file_path") @db.VarChar(1000)
  fileSize  BigInt @map("file_size")
  mimeType  String @map("mime_type") @db.VarChar(200)
  sortOrder Int    @default(0) @map("sort_order")

  createdBy BigInt?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  post CmsPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId], name: "ix_cms_attachment_m_post")
  @@map("cms_attachment_m")
  @@schema("cms")
}

// ============================================
// User Profile (확장 프로필)
// ============================================
model CmsUserProfile {
  id BigInt @id @default(autoincrement()) @map("profile_id")

  userId        BigInt  @unique @map("user_id")
  bio           String? @db.VarChar(2000)
  coverImageUrl String? @map("cover_image_url") @db.VarChar(1000)
  linkedinUrl   String? @map("linkedin_url") @db.VarChar(500)
  websiteUrl    String? @map("website_url") @db.VarChar(500)

  isActive      Boolean  @default(true) @map("is_active")
  createdBy     BigInt?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedBy     BigInt?  @map("updated_by")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lastSource    String?  @map("last_source")
  lastActivity  String?  @map("last_activity")
  transactionId String?  @map("transaction_id") @db.Uuid

  userSkills           CmsUserSkill[]
  careers              CmsUserCareer[]
  endorsementsReceived CmsEndorsement[] @relation("EndorseeProfile")

  @@map("cms_user_profile_m")
  @@schema("cms")
}

model CmsUserProfileHistory {
  profileId  BigInt @map("profile_id")
  historySeq BigInt @map("history_seq")

  eventType String   @map("event_type") @db.Char(1)
  eventAt   DateTime @default(now()) @map("event_at")
  eventBy   BigInt?  @map("event_by")

  userId        BigInt  @map("user_id")
  bio           String? @db.VarChar(2000)
  coverImageUrl String? @map("cover_image_url") @db.VarChar(1000)
  linkedinUrl   String? @map("linkedin_url") @db.VarChar(500)
  websiteUrl    String? @map("website_url") @db.VarChar(500)

  isActive      Boolean  @map("is_active")
  createdBy     BigInt?  @map("created_by")
  createdAt     DateTime @map("created_at")
  updatedBy     BigInt?  @map("updated_by")
  updatedAt     DateTime @map("updated_at")
  lastSource    String?  @map("last_source")
  lastActivity  String?  @map("last_activity")
  transactionId String?  @map("transaction_id") @db.Uuid

  @@id([profileId, historySeq], name: "pk_cms_user_profile_h")
  @@index([eventAt], name: "ix_cms_user_profile_h_event_at")
  @@index([transactionId], name: "ix_cms_user_profile_h_tx")
  @@map("cms_user_profile_h")
  @@schema("cms")
}

// ============================================
// Skill (스킬 마스터)
// ============================================
model CmsSkill {
  id BigInt @id @default(autoincrement()) @map("skill_id")

  skillName     String   @unique @map("skill_name") @db.VarChar(200)
  skillCategory String   @map("skill_category") @db.VarChar(100)
  parentSkillId BigInt?  @map("parent_skill_id")
  description   String?  @db.VarChar(1000)
  synonyms      String[] @default([])

  isActive      Boolean  @default(true) @map("is_active")
  createdBy     BigInt?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedBy     BigInt?  @map("updated_by")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lastSource    String?  @map("last_source")
  lastActivity  String?  @map("last_activity")
  transactionId String?  @map("transaction_id") @db.Uuid

  parentSkill  CmsSkill?        @relation("SkillHierarchy", fields: [parentSkillId], references: [id], onDelete: SetNull)
  childSkills  CmsSkill[]       @relation("SkillHierarchy")
  userSkills   CmsUserSkill[]
  endorsements CmsEndorsement[]

  @@index([skillCategory], name: "ix_cms_skill_m_category")
  @@index([parentSkillId], name: "ix_cms_skill_m_parent")
  @@map("cms_skill_m")
  @@schema("cms")
}

// ============================================
// User-Skill Relation (유저-스킬 매핑)
// ============================================
model CmsUserSkill {
  id BigInt @id @default(autoincrement()) @map("user_skill_id")

  profileId         BigInt @map("profile_id")
  skillId           BigInt @map("skill_id")
  proficiencyLevel  Int    @default(1) @map("proficiency_level")
  yearsOfExperience Int    @default(0) @map("years_of_experience")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile      CmsUserProfile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill        CmsSkill         @relation(fields: [skillId], references: [id], onDelete: Cascade)
  endorsements CmsEndorsement[]

  @@unique([profileId, skillId], name: "uq_cms_user_skill")
  @@index([skillId], name: "ix_cms_user_skill_r_skill")
  @@map("cms_user_skill_r")
  @@schema("cms")
}

// ============================================
// User Career (프로젝트 이력)
// ============================================
model CmsUserCareer {
  id BigInt @id @default(autoincrement()) @map("career_id")

  profileId   BigInt    @map("profile_id")
  projectId   BigInt?   @map("project_id")
  companyName String?   @map("company_name") @db.VarChar(200)
  projectName String    @map("project_name") @db.VarChar(300)
  roleName    String    @map("role_name") @db.VarChar(100)
  description String?   @db.VarChar(2000)
  startDate   DateTime  @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date

  isActive      Boolean  @default(true) @map("is_active")
  createdBy     BigInt?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedBy     BigInt?  @map("updated_by")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lastSource    String?  @map("last_source")
  lastActivity  String?  @map("last_activity")
  transactionId String?  @map("transaction_id") @db.Uuid

  profile CmsUserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId], name: "ix_cms_user_career_m_profile")
  @@index([projectId], name: "ix_cms_user_career_m_project")
  @@map("cms_user_career_m")
  @@schema("cms")
}

// ============================================
// Endorsement (스킬 추천/보증)
// ============================================
model CmsEndorsement {
  id BigInt @id @default(autoincrement()) @map("endorsement_id")

  endorserUserId    BigInt  @map("endorser_user_id")
  endorseeProfileId BigInt  @map("endorsee_profile_id")
  userSkillId       BigInt  @map("user_skill_id")
  skillId           BigInt  @map("skill_id")
  comment           String? @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")

  endorseeProfile CmsUserProfile @relation("EndorseeProfile", fields: [endorseeProfileId], references: [id], onDelete: Cascade)
  userSkill       CmsUserSkill   @relation(fields: [userSkillId], references: [id], onDelete: Cascade)
  skill           CmsSkill       @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([endorserUserId, userSkillId], name: "uq_cms_endorsement")
  @@index([endorseeProfileId], name: "ix_cms_endorsement_m_endorsee")
  @@index([skillId], name: "ix_cms_endorsement_m_skill")
  @@map("cms_endorsement_m")
  @@schema("cms")
}

// ============================================
// Follow (팔로우 관계)
// ============================================
model CmsFollow {
  id BigInt @id @default(autoincrement()) @map("follow_id")

  followerUserId  BigInt @map("follower_user_id")
  followingUserId BigInt @map("following_user_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([followerUserId, followingUserId], name: "uq_cms_follow")
  @@index([followingUserId], name: "ix_cms_follow_r_following")
  @@map("cms_follow_r")
  @@schema("cms")
}

// ============================================
// Bookmark (게시물 북마크)
// ============================================
model CmsBookmark {
  id BigInt @id @default(autoincrement()) @map("bookmark_id")

  userId BigInt @map("user_id")
  postId BigInt @map("post_id")

  createdAt DateTime @default(now()) @map("created_at")

  post CmsPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId], name: "uq_cms_bookmark")
  @@index([userId, createdAt], name: "ix_cms_bookmark_m_user")
  @@map("cms_bookmark_m")
  @@schema("cms")
}

// ============================================
// Notification (알림)
// ============================================
model CmsNotification {
  id BigInt @id @default(autoincrement()) @map("notification_id")

  recipientUserId  BigInt    @map("recipient_user_id")
  actorUserId      BigInt    @map("actor_user_id")
  notificationType String    @map("notification_type") @db.VarChar(50)
  referenceType    String    @map("reference_type") @db.VarChar(30)
  referenceId      BigInt    @map("reference_id")
  message          String    @db.VarChar(1000)
  isRead           Boolean   @default(false) @map("is_read")
  readAt           DateTime? @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([recipientUserId, isRead, createdAt], name: "ix_cms_notification_m_recipient")
  @@index([actorUserId], name: "ix_cms_notification_m_actor")
  @@map("cms_notification_m")
  @@schema("cms")
}
