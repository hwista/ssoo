  endorseeProfile ChUserProfile @relation("EndorseeProfile", fields: [endorseeProfileId], references: [id], onDelete: Cascade)
  userSkill       ChUserSkill   @relation(fields: [userSkillId], references: [id], onDelete: Cascade)
  skill           ChSkill       @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([endorserUserId, userSkillId], name: "uq_ch_endorsement")
  @@index([endorseeProfileId], name: "ix_ch_endorsement_m_endorsee")
  @@index([skillId], name: "ix_ch_endorsement_m_skill")
  @@map("ch_endorsement_m")
  @@schema("chs")
}

// ============================================
// Follow (팔로우 관계)
// ============================================
model ChFollow {
  id              BigInt   @id @default(autoincrement()) @map("follow_id")

  followerUserId  BigInt   @map("follower_user_id")
  followingUserId BigInt   @map("following_user_id")

  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([followerUserId, followingUserId], name: "uq_ch_follow")
  @@index([followingUserId], name: "ix_ch_follow_r_following")
  @@map("ch_follow_r")
  @@schema("chs")
}

// ============================================
// Bookmark (게시물 북마크)
// ============================================
model ChBookmark {
  id              BigInt   @id @default(autoincrement()) @map("bookmark_id")

  userId          BigInt   @map("user_id")
  postId          BigInt   @map("post_id")

  createdAt       DateTime @default(now()) @map("created_at")

  post            ChPost   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId], name: "uq_ch_bookmark")
  @@index([userId, createdAt], name: "ix_ch_bookmark_m_user")
  @@map("ch_bookmark_m")
  @@schema("chs")
}

// ============================================
// Notification (알림)
// ============================================
model ChNotification {
  id              BigInt   @id @default(autoincrement()) @map("notification_id")

  recipientUserId BigInt   @map("recipient_user_id")
  actorUserId     BigInt   @map("actor_user_id")
  notificationType String  @map("notification_type") @db.VarChar(50)
  referenceType   String   @map("reference_type") @db.VarChar(30)
  referenceId     BigInt   @map("reference_id")
  message         String   @db.VarChar(1000)
  isRead          Boolean  @default(false) @map("is_read")
  readAt          DateTime? @map("read_at")

  createdAt       DateTime @default(now()) @map("created_at")

  @@index([recipientUserId, isRead, createdAt], name: "ix_ch_notification_m_recipient")
  @@index([actorUserId], name: "ix_ch_notification_m_actor")
  @@map("ch_notification_m")
  @@schema("chs")
}
