// ============================================
// Task (태스크/WBS) - pr_task_m
// 계층 구조 지원 (parentTaskId → self-reference)
// ============================================
model Task {
  id              BigInt   @id @default(autoincrement()) @map("task_id")

  projectId       BigInt   @map("project_id")
  parentTaskId    BigInt?  @map("parent_task_id")

  taskCode        String   @map("task_code") @db.VarChar(50) // WBS 코드 (예: "1.1.2")
  taskName        String   @map("task_name")
  description     String?

  taskTypeCode    String?  @map("task_type_code") // development, design, test, review, deployment, management
  statusCode      String   @default("not_started") @map("status_code") // not_started, in_progress, completed, on_hold, cancelled
  priorityCode    String   @default("normal") @map("priority_code") // critical, high, normal, low

  assigneeUserId  BigInt?  @map("assignee_user_id")

  plannedStartAt  DateTime? @map("planned_start_at") @db.Date
  plannedEndAt    DateTime? @map("planned_end_at") @db.Date
  actualStartAt   DateTime? @map("actual_start_at") @db.Date
  actualEndAt     DateTime? @map("actual_end_at") @db.Date

  progressRate    Int      @default(0) @map("progress_rate") // 0-100
  estimatedHours  Decimal? @map("estimated_hours") @db.Decimal(8, 1)
  actualHours     Decimal? @map("actual_hours") @db.Decimal(8, 1)

  depth           Int      @default(0) // WBS 깊이 (0 = root)
  sortOrder       Int      @default(0) @map("sort_order")

  // Common columns
  isActive        Boolean  @default(true) @map("is_active")
  memo            String?
  createdBy       BigInt?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedBy       BigInt?  @map("updated_by")
  updatedAt       DateTime @updatedAt @map("updated_at")
  lastSource      String?  @map("last_source")
  lastActivity    String?  @map("last_activity")
  transactionId   String?  @map("transaction_id") @db.Uuid

  // Relations
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentTask      Task?    @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks      Task[]   @relation("TaskHierarchy")
  assignee        User?    @relation("TaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)

  @@unique([projectId, taskCode], name: "uq_pr_task_m_project_code")
  @@index([projectId, statusCode], name: "ix_pr_task_m_project_status")
  @@index([projectId, parentTaskId], name: "ix_pr_task_m_hierarchy")
  @@index([assigneeUserId], name: "ix_pr_task_m_assignee")
  @@index([updatedAt], name: "ix_pr_task_m_updated_at")
  @@map("pr_task_m")
  @@schema("pms")
}

