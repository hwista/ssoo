  issueCode   String  @map("issue_code") @db.VarChar(50) // 예: "ISS-001"
  issueTitle  String  @map("issue_title")
  description String?

  issueTypeCode String @map("issue_type_code") // bug, requirement_change, risk, impediment, inquiry
  statusCode    String @default("open") @map("status_code") // open, in_progress, resolved, closed, deferred
  priorityCode  String @default("normal") @map("priority_code") // critical, high, normal, low

  reportedByUserId BigInt? @map("reported_by_user_id")
  assigneeUserId   BigInt? @map("assignee_user_id")

  reportedAt DateTime  @default(now()) @map("reported_at")
  dueAt      DateTime? @map("due_at") @db.Date
  resolvedAt DateTime? @map("resolved_at")

  resolution String? // 해결 내용

  sortOrder Int @default(0) @map("sort_order")

  // Common columns
  isActive      Boolean  @default(true) @map("is_active")
  memo          String?
  createdBy     BigInt?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedBy     BigInt?  @map("updated_by")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lastSource    String?  @map("last_source")
  lastActivity  String?  @map("last_activity")
  transactionId String?  @map("transaction_id") @db.Uuid

  // Relations
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reportedBy User?   @relation("IssueReporter", fields: [reportedByUserId], references: [id], onDelete: SetNull)
  assignee   User?   @relation("IssueAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)

  @@unique([projectId, issueCode], name: "uq_pr_issue_m_project_code")
  @@index([projectId, statusCode], name: "ix_pr_issue_m_project_status")
  @@index([projectId, issueTypeCode], name: "ix_pr_issue_m_project_type")
  @@index([assigneeUserId], name: "ix_pr_issue_m_assignee")
  @@index([updatedAt], name: "ix_pr_issue_m_updated_at")
  @@map("pr_issue_m")
  @@schema("pms")
}

