  createdBy       BigInt?  @map("created_by")
  createdAt       DateTime @map("created_at")
  updatedBy       BigInt?  @map("updated_by")
  updatedAt       DateTime @map("updated_at")
  lastSource      String?  @map("last_source")
  lastActivity    String?  @map("last_activity")
  transactionId   String?  @map("transaction_id") @db.Uuid

  @@id([commentId, historySeq], name: "pk_ch_comment_h")
  @@index([eventAt], name: "ix_ch_comment_h_event_at")
  @@index([transactionId], name: "ix_ch_comment_h_tx")
  @@map("ch_comment_h")
  @@schema("chs")
}

// ============================================
// Reaction (반응/좋아요 — 다형성: 게시물·댓글)
// ============================================
model ChReaction {
  id              BigInt   @id @default(autoincrement()) @map("reaction_id")

  userId          BigInt   @map("user_id")
  postId          BigInt?  @map("post_id")
  commentId       BigInt?  @map("comment_id")
  reactionType    String   @default("like") @map("reaction_type") @db.VarChar(30)

  createdAt       DateTime @default(now()) @map("created_at")

  post            ChPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment         ChComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, reactionType], name: "uq_ch_reaction_post")
  @@unique([userId, commentId, reactionType], name: "uq_ch_reaction_comment")
  @@index([postId], name: "ix_ch_reaction_m_post")
  @@index([commentId], name: "ix_ch_reaction_m_comment")
  @@map("ch_reaction_m")
  @@schema("chs")
}

// ============================================
