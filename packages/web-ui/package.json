{
  "name": "@ssoo/web-ui",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tailwind-preset": {
      "types": "./tailwind-preset.d.ts",
      "require": "./tailwind-preset.cjs",
      "default": "./tailwind-preset.cjs"
    }
