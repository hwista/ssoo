{
  "schemaVersion": 1,
  "package": "@ssoo/web-ui",
  "policy": {
    "platform": "Every declared primitive is owned by @ssoo/web-ui. App-local components/ui files may only thin re-export it.",
    "appAdapter": "Apps may keep components/ui/* compatibility files, but primitive recipes, Radix wrappers, markup, variant, color, size, radius, focus, and control-height classes must not be redefined outside @ssoo/web-ui."
  },
  "primitives": {
    "alert-dialog": {
      "status": "platform",
      "source": "packages/web-ui/src/alert-dialog.tsx",
      "exports": ["AlertDialog", "AlertDialogPortal", "AlertDialogOverlay", "AlertDialogTrigger", "AlertDialogContent", "AlertDialogHeader", "AlertDialogFooter", "AlertDialogTitle", "AlertDialogDescription", "AlertDialogAction", "AlertDialogCancel"],
      "parameters": ["open", "defaultOpen", "onOpenChange", "className"]
    },
