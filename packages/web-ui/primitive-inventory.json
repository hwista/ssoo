      "status": "platform",
      "source": "packages/web-ui/src/avatar.tsx",
      "exports": ["Avatar", "AvatarImage", "AvatarFallback"],
      "parameters": ["className", "src", "alt", "children"]
    },
    "badge": {
      "status": "platform",
      "source": "packages/web-ui/src/badge.tsx",
      "exports": ["Badge", "BadgeProps", "badgeVariants"],
      "parameters": ["variant", "className"],
      "classNamePolicy": "layout-only overrides allowed at call sites; recipe classes must stay in @ssoo/web-ui"
    },
    "button": {
      "status": "platform",
      "source": "packages/web-ui/src/button.tsx",
      "exports": ["Button", "ButtonProps", "buttonVariants"],
