{
  "name": "sooo",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "description": "SSOO - SI/SM 조직의 Opportunity-Project-System 통합 업무 허브",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "COREPACK_HOME=${COREPACK_HOME:-/tmp/corepack} corepack pnpm --filter @ssoo/database db:generate",
    "db:push": "DATABASE_URL=${DATABASE_URL:-postgresql://ssoo:ssoo_dev_pw@localhost:5432/ssoo_dev?schema=public} COREPACK_HOME=${COREPACK_HOME:-/tmp/corepack} corepack pnpm --filter @ssoo/database db:push",
    "db:seed": "bash .codex/scripts/db-seed.sh",
    "db:triggers": "DATABASE_URL=${DATABASE_URL:-postgresql://ssoo:ssoo_dev_pw@localhost:5432/ssoo_dev?schema=public} COREPACK_HOME=${COREPACK_HOME:-/tmp/corepack} corepack pnpm --filter @ssoo/database exec ts-node --project tsconfig.json scripts/apply-triggers.ts",
    "db:setup": "bash .codex/scripts/db-setup.sh",
    "lint:docs": "node .github/scripts/check-docs.js --strict-warnings",
    "clean": "turbo clean && rimraf node_modules",
    "docs:typedoc": "pnpm --filter server docs:typedoc && pnpm --filter web-pms docs:typedoc && pnpm --filter @ssoo/types docs:typedoc",
    "docs:openapi": "pnpm --filter server docs:openapi",
    "docs:db": "pnpm --filter @ssoo/database docs:db",
    "docs:storybook": "pnpm --filter web-pms build-storybook",
    "docs:all": "pnpm docs:typedoc && pnpm docs:openapi && pnpm docs:db && pnpm docs:storybook && pnpm docs:verify",
    "docs:verify": "node scripts/docs-verify.js",
    "changelog": "conventional-changelog -p angular -i docs/CHANGELOG.md -s",
    "changelog:init": "conventional-changelog -p angular -i docs/CHANGELOG.md -s -r 0",
    "dev:server": "turbo dev --filter=server",
    "dev:web-pms": "turbo dev --filter=web-pms",
    "dev:web-dms": "cd apps/web/dms && npm run dev",
    "build:server": "turbo build --filter=server",
    "build:web-pms": "turbo build --filter=web-pms",
    "dev:web-chs": "turbo dev --filter=web-chs",
    "build:web-chs": "turbo build --filter=web-chs",
    "build:web-dms": "bash .codex/scripts/dms-build.sh",
    "codex:verify-sync": "node .codex/scripts/verify-codex-sync.js",
    "codex:check": "pnpm run codex:verify-sync && bash .codex/hooks/preflight.sh",
    "codex:preflight": "bash .codex/hooks/preflight.sh",
    "codex:dms-guard": "bash .codex/hooks/dms-guard.sh",
    "codex:push-guard": "bash .codex/hooks/push-guard.sh",
    "codex:workspace-sync-from-gitlab": "bash .codex/scripts/workspace-sync-from-gitlab.sh",
    "codex:workspace-publish": "bash .codex/scripts/workspace-publish.sh",
    "codex:dms-sync-from-gitlab": "bash .codex/scripts/dms-sync-from-gitlab.sh",
    "codex:dms-publish": "bash .codex/scripts/dms-publish.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "conventional-changelog-cli": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "rimraf": "^6.0.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx}": [
      "pnpm run lint",
      "node .github/scripts/check-patterns.js"
    ],
    "packages/**/*.{ts,tsx}": [
      "pnpm run lint",
      "node .github/scripts/check-patterns.js"
    ],
    "docs/**/*.md": [
      "node .github/scripts/check-docs.js --strict-warnings"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
