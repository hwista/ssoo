# Database
DATABASE_URL="postgresql://ssoo:ssoo_dev_pw@localhost:5432/ssoo_dev?schema=public"

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004
AUTH_PUBLIC_API_BASE_URL=http://localhost:4000/api
AUTH_TRUST_FORWARD_HEADERS=false
# Local Docker compose may set this true because the sample stack runs NODE_ENV=production with local defaults.
# Do not enable it in real production.
AUTH_ALLOW_INSECURE_PRODUCTION_DEFAULTS=false

# JWT Configuration (필수)
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_SESSION_COOKIE_NAME=ssoo-session
AUTH_SESSION_COOKIE_DOMAIN=
AUTH_SESSION_COOKIE_SECURE=false
AUTH_SESSION_COOKIE_SAME_SITE=lax
AUTH_MICROSOFT_OAUTH_STATE_COOKIE_NAME=ssoo-ms-oauth-state
AUTH_OAUTH_STATE_SIGNING_SECRET=
# Required when storing Microsoft client secret from Admin. Replace in every non-local environment.
AUTH_CONFIG_ENCRYPTION_KEY=change-me-auth-config-encryption-key-32chars
AUTH_DEFAULT_LOGIN_URL=http://localhost:3000/login

# Browser-facing API URLs for Docker/local frontends
PMS_NEXT_PUBLIC_API_URL=http://localhost:4000/api
SNS_NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:3000
NEXT_PUBLIC_CRM_APP_URL=http://localhost:3001
NEXT_PUBLIC_PMS_APP_URL=http://localhost:3002
NEXT_PUBLIC_DMS_APP_URL=http://localhost:3003
NEXT_PUBLIC_SNS_APP_URL=http://localhost:3004
# Optional shared login extensions. Empty values keep these actions hidden.
# Admin-managed auth settings override these fallback links when /api/auth/public-config is available.
NEXT_PUBLIC_AUTH_PASSWORD_RESET_URL=
NEXT_PUBLIC_AUTH_SIGNUP_REQUEST_URL=
# Use open signup only when self-registration is explicitly allowed.
NEXT_PUBLIC_AUTH_SIGNUP_URL=
# Internal company SSO entrypoint.
NEXT_PUBLIC_AUTH_SSO_URL=
# Microsoft Entra ID / Microsoft 365 OAuth entrypoint.
NEXT_PUBLIC_AUTH_OAUTH_MICROSOFT_URL=
PMS_SERVER_API_URL=http://server:4000/api
SNS_SERVER_API_URL=http://server:4000/api

# Optional compose-only overrides (use internal service hostnames here)
DOCKER_DATABASE_URL=postgresql://ssoo:ssoo_dev_pw@postgres:5432/ssoo_dev?schema=public
DOCKER_DMS_DATABASE_URL=postgresql://ssoo:ssoo_dev_pw@postgres:5432/ssoo_dev?schema=public

# DMS external runtime paths (container paths)
DMS_MARKDOWN_ROOT=/var/lib/ssoo/documents
DMS_INGEST_QUEUE_PATH=/var/lib/ssoo/document-ingest
DMS_STORAGE_LOCAL_BASE_PATH=/var/lib/ssoo/document-storage/local
DMS_STORAGE_SHAREPOINT_BASE_PATH=/sites/documents/shared-documents
DMS_STORAGE_NAS_BASE_PATH=/mnt/nas/documents

# DMS Git role contract
# Local/direct-run development should use dev. Deployed server/production should use prod.
DMS_INSTANCE_ENV=dev
DMS_GIT_PROD_REMOTE_URL=http://10.125.31.72:8010/LSITC_WEB/LSWIKI_DOC.git
DMS_GIT_DEV_REMOTE_URL=git@10.125.31.72:LSITC_WEB/LSWIKI_DOC_DEV.git
# Leave BOOTSTRAP_REMOTE_URL blank unless you are intentionally clearing a stale persisted value
# or overriding to the same remote that the current DMS_INSTANCE_ENV expects.
DMS_GIT_BOOTSTRAP_REMOTE_URL=
DMS_GIT_BOOTSTRAP_BRANCH=master
# Comma-separated directory prefixes that remain local-only and never enter DMS Git publish.
DMS_GIT_PUBLISH_IGNORED_PATH_PREFIXES=launch-smoke/,codex-lock-ui/,codex-lock-probe/,verify-access/

# DMS AI / Azure OpenAI (server container reads these via compose.yaml)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
# Optional for chat-only use. Required for embedding/vector indexing and semantic search.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
OPENAI_API_VERSION=2024-10-21

# Azure auth: prefer managed identity or service principal; API key is fallback.
AZURE_USE_MANAGED_IDENTITY=true
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_MANAGED_IDENTITY_CLIENT_ID=
AZURE_OPENAI_API_KEY=

# DMS external runtime paths (host paths for compose bind mounts)
DMS_MARKDOWN_HOST_PATH=./.runtime/documents
DMS_INGEST_HOST_PATH=./.runtime/document-ingest
DMS_STORAGE_LOCAL_HOST_PATH=./.runtime/document-storage/local
