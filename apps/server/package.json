{
    "name": "server",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "nest build",
        "clean": "rimraf dist",
        "dev": "nest start --watch",
        "docs:typedoc:common": "typedoc --options typedoc.common.json",
        "docs:typedoc:pms": "typedoc --options typedoc.pms.json",
        "docs:typedoc": "pnpm run docs:typedoc:common && pnpm run docs:typedoc:pms",
        "start": "nest start",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,test}/**/*.ts\" --fix",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
        "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
        "test:cov": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
        "docs:openapi": "ts-node --project tsconfig.json scripts/generate-openapi.ts"
    },
    "dependencies": {
        "@ai-sdk/azure": "^3.0.28",
        "@azure/identity": "4.6.0",
        "@napi-rs/canvas": "^0.1.97",
        "@nestjs/common": "^10.4.0",
        "@nestjs/config": "^3.3.0",
        "@nestjs/core": "^10.4.0",
        "@nestjs/jwt": "^10.2.0",
        "@nestjs/passport": "^10.0.0",
        "@nestjs/platform-express": "^10.4.0",
        "@nestjs/platform-socket.io": "^10.4.0",
        "@nestjs/swagger": "^8.1.0",
        "@nestjs/terminus": "^10.2.0",
        "@nestjs/throttler": "^6.5.0",
        "@nestjs/websockets": "^10.4.0",
        "@ssoo/database": "workspace:*",
        "@ssoo/types": "workspace:*",
        "adm-zip": "^0.5.17",
        "ai": "^6.0.81",
        "bcryptjs": "^3.0.3",
        "class-transformer": "^0.5.0",
        "class-validator": "^0.14.0",
        "dayjs": "^1.11.0",
        "eslint-plugin-import": "^2.32.0",
        "helmet": "^8.0.0",
        "joi": "^18.0.2",
        "mammoth": "^1.12.0",
        "nestjs-pino": "^4.1.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.0",
        "pdfjs-dist": "^5.6.205",
        "pino-http": "^10.0.0",
        "reflect-metadata": "^0.2.0",
        "rxjs": "^7.8.0",
        "simple-git": "^3.35.2",
        "socket.io": "^4.8.0",
        "swagger-ui-express": "^5.0.0",
        "unpdf": "^1.4.0",
        "uuid": "^11.0.0",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@nestjs/cli": "^10.4.0",
        "@nestjs/schematics": "^10.1.0",
        "@nestjs/testing": "^10.4.22",
        "@redocly/cli": "^2.14.9",
        "@types/adm-zip": "^0.5.8",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.0.0",
        "@types/passport-jwt": "^4.0.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "eslint": "^9.0.0",
        "eslint-plugin-import": "^2.32.0",
        "globals": "^17.0.0",
        "jest": "^29.7.0",
        "pino-pretty": "^13.0.0",
        "rimraf": "^6.0.0",
        "ts-jest": "^29.4.9",
        "ts-node": "^10.9.2",
        "typedoc": "^0.28.16",
        "typescript": "^5.7.0"
    }
}
